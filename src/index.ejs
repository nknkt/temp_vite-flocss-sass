<!DOCTYPE html>
<html lang="ja">
  <head>
    <link rel="preconnect" href="https://www.googletagmanager.com">
    <!--#include file="assets/includes/gtm-head.html" -->
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>%TITLE%</title>
    <meta name="description" content="%DESCRIPTION%">
    <meta name="format-detection" content="telephone=no">

    <meta property="og:title" content="%TITLE%">
    <meta property="og:description" content="%DESCRIPTION%">
    <meta property="og:image" content="./assets/images/og.png">
    <meta property="og:url" content="%URL%">
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="%SITE_NAME%">

    <link rel="canonical" href="%URL%">
    <!-- <meta name="robots" content="noindex"> -->

    <link rel="preload" as="image" href="%LCP_SRC%" fetchpriority="high">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preconnect" href="https://www.google-analytics.com">
    <!--#include file="assets/includes/fonts.html" -->

    <link rel="shortcut icon" href="./favicon.ico">
    <link rel="stylesheet" href="./assets/styles/common.scss">
    <link rel="stylesheet" href="./assets/styles/object/pages/index/_index.scss">
  </head>

  <body>
    <!--#include file="assets/includes/gtm-body.html" -->

    <svg xmlns="http://www.w3.org/2000/svg" style="display: none;">
      <symbol id="logo" viewBox="0 0 160 40">
        <rect width="40" height="40" rx="6" fill="currentColor" />
        <text x="50" y="28" font-family="sans-serif" font-size="20" font-weight="700" fill="currentColor"
          letter-spacing="1">LOGO</text>
      </symbol>
    </svg>

    <div class="l-page">
      <!--#include file="assets/includes/header.html" -->

      <main class="l-main">
        <section id="sample" style="padding: 10rem 0">
          <h2 class="c-section-head u-fade-in">
            <span class="c-section-head__en">Sample</span>
            <span class="c-section-head__ja">サンプルセクション</span>
          </h2>

          <div class="u-wrapper" style="margin-top: 5rem">
            <div class="u-fade-in" style="max-width: 80rem; margin-inline: auto; text-align: center">

              <%# 変数の出力サンプル %>
              <% const pageTitle = 'トップページ' %>
              <p style="font-size: 1.8rem; font-weight: 700; margin-bottom: 2rem">
                <%= pageTitle %>
              </p>

              <%# if サンプル（isNewフラグで出し分け） %>
              <% const sampleItems = [
                { label: 'アイテムA', isNew: true },
                { label: 'アイテムB', isNew: false },
                { label: 'アイテムC', isNew: true },
              ] %>
              <ul style="margin-top: 2rem; list-style: none; display: flex; gap: 1rem; justify-content: center">
                <% sampleItems.forEach(function(item) { %>
                <li style="font-size: 1.4rem; padding: 0.5rem 1.5rem; border: 1px solid currentColor">
                  <%= item.label %>
                  <% if (item.isNew) { %>
                  <span style="font-size: 1.2rem; color: red; margin-left: 0.5rem">NEW</span>
                  <% } %>
                </li>
                <% }) %>
              </ul>

            </div>
          </div>
        </section>

        <div id="about" class="p-about">
          <div>
            <div class="p-about__logo">
              <svg aria-label="ブランド名" role="img"><use href="#logo" /></svg>
            </div>
            <a class="p-about__link c-link-text" href="/" target="_blank"> 公式サイト（サンプル） </a>
          </div>
          <p class="p-about__note">
            これは既存のp-aboutコンポーネントのサンプルです。<br>
            背景色やレイアウトがSCSSで定義されています。<br>
            このまま使用するか、削除して新しいセクションを作成してください。
          </p>
        </div>

        <section id="contact" style="padding: 10rem 0">
          <h2 class="c-section-head u-fade-in">
            <span class="c-section-head__en">Contact</span>
            <span class="c-section-head__ja">お問い合わせ</span>
          </h2>

          <div class="u-wrapper" style="margin-top: 5rem">
            <div class="u-fade-in" style="max-width: 80rem; margin-inline: auto; text-align: center">
              <p style="font-size: 1.6rem; line-height: 2; margin-bottom: 3rem">
                ご質問やお問い合わせは下記よりお気軽にご連絡ください。
              </p>
              <a href="#" class="c-link-text">お問い合わせフォームへ</a>
            </div>
          </div>
        </section>


      </main>

      <!--#include file="assets/includes/footer.html" -->
    </div>

    <script type="module" src="./assets/scripts/pages/index/index.js"></script>
  </body>
</html>
